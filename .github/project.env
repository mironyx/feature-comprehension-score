# GitHub Project Board configuration
# Used by scripts/gh-project-status.sh and scripts/gh-create-issue.sh
#
# To set up for a new repo:
#   1. Create a project board in GitHub
#   2. Run: gh project field-list <number> --owner <owner>
#   3. Find the Status field ID and its option IDs
#   4. Fill in the values below

REPO=mironyx/feature-comprehension-score
PROJECT_NUMBER=2
PROJECT_ID=PVT_kwDOEEi_vs4BToGD
FIELD_ID=PVTSSF_lADOEEi_vs4BToGDzhA10G4
STATUS_TODO=8d4368d4
STATUS_BLOCKED=3aacb396
STATUS_IN_PROGRESS=3317982f
STATUS_DONE=8c0ec0d7
