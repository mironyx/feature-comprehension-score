{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_METRIC_EXPORT_INTERVAL": "5000",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative"
  },
  "permissions": {
    "allow": [
      "Bash(gh run list*)",
      "Bash(gh run watch*)",
      "Bash(gh run view*)",
      "Bash(gh pr checks*)",
      "WebSearch",
      "WebFetch",
      "Bash(git checkout*)",
      "Bash(gh pr comment*)",
      "Bash(gh issue close*)",
      "Bash(./scripts/gh-project-status.sh*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/open-in-editor.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-diagnostics.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-python.sh scripts/pre-compact-session-log.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "enableAllProjectMcpServers": true
}
