{
  "permissions": {
    "allow": [
      "Bash(git*)",
      "Bash(gh*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(node*)",
      "Bash(python3*)",
      "Bash(bash scripts/*)",
      "Bash(.claude/hooks/*)",
      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(mkdir*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(docker*)",
      "Bash(pwd)",
      "WebFetch(domain:docs.github.com)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright-test"
  ],
  "prefersReducedMotion": true,
  "hooks": {
    "PostToolUse": []
  }
}
