# Integration test environment — copy to .env.test.local and fill in real values.
# Get values from: npx supabase status --output json
#
# Do NOT commit .env.test.local — it is gitignored.

# Used by app (Next.js) and setup.ts fallbacks
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<ANON_KEY from supabase status>
SUPABASE_SECRET_KEY=<SERVICE_ROLE_KEY from supabase status>

# Used by supabase-env.ts in integration test helpers
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=<ANON_KEY from supabase status>
