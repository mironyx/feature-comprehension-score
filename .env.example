# Environment variables required to run the application.
# Copy this file to .env.local and fill in real values.

# Supabase — get values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# OpenRouter — get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: override the default model (default: deepseek/deepseek-v3.2)
# OPENROUTER_MODEL=deepseek/deepseek-v3.2

# GitHub App — webhook secret from your GitHub App registration (Settings → Developer settings → GitHub Apps)
# Note: this is separate from the GitHub OAuth App used for Supabase Auth login
GITHUB_WEBHOOK_SECRET=your-github-app-webhook-secret
