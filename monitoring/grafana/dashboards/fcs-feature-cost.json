{
  "title": "FCS — Feature Cost & Token Usage",
  "uid": "fcs-feature-cost",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Cost by Feature (USD)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (feature_id) (claude_code_cost_usage_USD_total * on(session_id) group_left(feature_id) claude_session_feature)",
          "legendFormat": "{{feature_id}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Token Usage by Feature & Type",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "stacking": "none",
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (feature_id, type) (claude_code_token_usage_tokens_total * on(session_id) group_left(feature_id) claude_session_feature)",
          "legendFormat": "{{feature_id}} / {{type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (feature_id) (increase(claude_code_cost_usage_USD_total[5m]) * on(session_id) group_left(feature_id) claude_session_feature)",
          "legendFormat": "{{feature_id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Input vs Output Tokens Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (feature_id, type) (claude_code_token_usage_tokens_total * on(session_id) group_left(feature_id) claude_session_feature)",
          "legendFormat": "{{feature_id}} / {{type}}"
        }
      ]
    }
  ]
}
